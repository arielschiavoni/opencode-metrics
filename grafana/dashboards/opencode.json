          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "targets": [
        {
          "expr": "(sum(sum_over_time(opencode_llm_call_cost_usd{provider=~\"$provider\",model=~\"$model\"}[$__range])) / ($__range_s / 86400)) and on() (vector($__range_s) >= 86400)",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Cache Hit Rate",
      "id": 8,
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
