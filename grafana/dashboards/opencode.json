      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "teal", "value": null }] },
          "unit": "short",
          "decimals": 0
        }
      },
      "targets": [{ "expr": "sum(sum_over_time(opencode_llm_call_tokens{type=\"output\",provider=~\"$provider\",model=~\"$model\"}[$__range]))", "refId": "A" }]
    },
    {
