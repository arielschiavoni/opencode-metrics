{
  "title": "OpenCode",
  "uid": "opencode",
  "tags": ["opencode"],
  "timezone": "browser",
  "refresh": "5m",
  "schemaVersion": 39,
  "time": { "from": "now/M", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "provider",
        "label": "Provider",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(opencode_llm_call_cost_usd, provider)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(opencode_llm_call_cost_usd{provider=~\"$provider\"}, model)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [

    {
      "type": "row",
      "title": "Totals",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Sessions",
      "id": 2,
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "decimals": 0
        }
      },
      "targets": [{ "expr": "sum(sum_over_time(opencode_session_total{provider=~\"$provider\",model=~\"$model\"}[$__range]))", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Input Tokens",
      "id": 3,
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short",
          "decimals": 0
        }
      },
      "targets": [{ "expr": "sum(sum_over_time(opencode_llm_call_tokens{type=\"input\",provider=~\"$provider\",model=~\"$model\"}[$__range]))", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Output Tokens",
      "id": 4,
