            "fillOpacity": 80,
            "stacking": { "mode": "normal", "group": "A" },
            "spanNulls": false
          }
        }
      },
      "targets": [{
        "expr": "sum by (provider) (sum_over_time(opencode_llm_call_tokens{provider=~\"$provider\",model=~\"$model\"}[$__interval]))",
