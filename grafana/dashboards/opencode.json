    {
      "type": "stat",
      "title": "Avg Daily Cost (USD)",
      "id": 25,
      "gridPos": {
        "x": 6,
        "y": 6,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "options": {
        "reduceOptions": {
