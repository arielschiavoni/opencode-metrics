      "targets": [
        {
          "expr": "sum(sum_over_time(opencode_llm_call_tokens{type=\"cache_read\",provider=~\"$provider\",model=~\"$model\"}[$__range])) / sum(sum_over_time(opencode_llm_call_tokens{type=~\"cache_read|input\",provider=~\"$provider\",model=~\"$model\"}[$__range]))",
          "refId": "A"
