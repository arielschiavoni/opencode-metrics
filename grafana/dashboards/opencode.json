      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] },
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "targets": [{ "expr": "sum(sum_over_time(opencode_llm_call_cost_usd{provider=~\"$provider\",model=~\"$model\"}[$__range]))", "refId": "A" }]
